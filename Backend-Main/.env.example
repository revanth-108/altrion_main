# Server Configuration
PORT=8000
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000/api

# Supabase Configuration (REQUIRED)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Supabase Postgres) (REQUIRED)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_TTL_RAW_DATA=86400  # 24 hours in seconds

# Payment Gateway Abstraction
PAYMENT_GATEWAY=hosted_payments_page
PAYMENT_WEBHOOK_SECRET=
PAYMENT_MERCHANT_ID=
PAYMENT_PUBLIC_KEY=

# Hosted Payments Page Provider
HPP_API_URL=
HPP_API_KEY=
HPP_ACCOUNT_ID=
HPP_PROFILE_ID=
HPP_ACCESS_KEY=
HPP_SECRET_KEY=
HPP_WEBHOOK_SECRET=
HPP_RETURN_URL=http://localhost:5173/subscription/success
HPP_CANCEL_URL=http://localhost:5173/pricing
HPP_LOCALE=en
HPP_CURRENCY=usd
HPP_TRANSACTION_TYPE=sale,create_payment_token

# Subscription Settings
DEFAULT_TRIAL_DAYS=14
ADMIN_EMAILS=admin@altrion.com,another.admin@altrion.com

# Optional: Plaid Configuration (only if using Plaid)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENVIRONMENT=sandbox
PLAID_WEBHOOK_URL=

# Optional: Coinbase Configuration (only if using Coinbase)
COINBASE_CLIENT_ID=your-coinbase-client-id
COINBASE_CLIENT_SECRET=your-coinbase-client-secret
COINBASE_REDIRECT_URI=http://localhost:8000/api/platforms/coinbase/callback

# Optional: CoinMarketCap API (only if using live price data)
COINMARKETCAP_API_KEY=your-coinmarketcap-api-key

# Optional: Moralis (wallet holdings across EVM chains)
MORALIS_API_KEY=

# Rate Limiting
REFRESH_RATE_LIMIT_MINUTES=5

# Security
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
JWT_ALGORITHM=HS256
SECURE_HEADERS=true

# Logging
LOG_LEVEL=INFO
