en.\n\nFlow:\n1. Frontend completes Plaid Link UI → receives public_token\n2. Frontend calls this endpoint with the public_token\n3. We exchange it for access_token + item_id\n4. We store the token in provider_tokens (one row per bank)\n5. We fetch and store the bank accounts\n6. Returns item_id and list of connected accounts\n\nThis is separate from /platforms/plaid/connect to:\n- Support multi-bank connections (each bank = separate item_id)\n- Store richer account metadata (subtype, mask, institution)\n- Use the dedicated Plaid controller instead of generic platforms","operationId":"exchange_token_api_plaid_exchange_token_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ExchangeTokenRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}},"security":[{"HTTPBearer":[]}]}},"/api/plaid/accounts":{"get":{"tags":["plaid"],"summary":"Get Accounts","description":"Get all accounts for the connected Plaid item.\n\nReturns cached account data (fast).\nFor live balances use /accounts/balances instead.\n\nQuery params:\n    item_id: Optional. If user has multiple banks connected,\n             specify which item to fetch. Defaults to most recent.","operationId":"get_accounts_api_plaid_accounts_get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/accounts/balances":{"get":{"tags":["plaid"],"summary":"Get Balances","description":"Get real-time balances for connected accounts.\n\nTriggers a live refresh from the bank — higher latency than /accounts.\nUse this when you need guaranteed fresh balance data.\n\nQuery params:\n    item_id: Optional. Specify which bank if multiple connected.\n    account_ids: Optional comma-separated list of account IDs to filter.\n                 Example: ?account_ids=acc123,acc456","operationId":"get_balances_api_plaid_accounts_balances_get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}},{"name":"account_ids","in":"query","required":false,"schema":{"type":"string","title":"Account Ids"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/accounts/sync":{"post":{"tags":["plaid"],"summary":"Sync Account Balances","description":"Sync Plaid account balances into the holdings table.\n\nThis is what makes the dashboard show real balance values.\nFlow:\n1. Fetch live balances from Plaid\n2. For each depository/credit account → write USD balance to holdings\n3. Dashboard aggregation picks up from holdings table automatically\n\nCall this after connecting a bank and periodically to refresh.\n\nQuery params:\n    item_id: Optional. Specify which bank if multiple connected.","operationId":"sync_account_balances_api_plaid_accounts_sync_post","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/item/status":{"get":{"tags":["plaid"],"summary":"Get Item Status","description":"Get full status of a connected Plaid Item (bank connection).\n\nReturns item health, error state, available products,\nconsent expiration, and webhook config.\n\nUse this to detect if a bank needs re-authentication\n(error.error_code == 'ITEM_LOGIN_REQUIRED').\n\nQuery params:\n    item_id: Optional. Specify which bank if multiple connected.","operationId":"get_item_status_api_plaid_item_status_get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/item":{"delete":{"tags":["plaid"],"summary":"Remove Item","description":"Disconnect a bank account (remove a Plaid Item).\n\nThis will:\n1. Revoke the access_token on Plaid's side\n2. Delete the provider_token row from the database\n3. Mark all related accounts as inactive\n4. Remove related holdings\n\nQuery params:\n    item_id: Optional. Specify which bank to disconnect.\n             If not provided, disconnects the most recently connected bank.","operationId":"remove_item_api_plaid_item_delete","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/transactions/sync":{"post":{"tags":["plaid"],"summary":"Sync Transactions","description":"Sync transactions from Plaid using cursor-based incremental sync.\n\nFirst call fetches full transaction history.\nSubsequent calls only fetch new/modified/removed transactions\nsince the last sync (using stored cursor).\n\nSynced transactions are stored in the transactions table.\n\nQuery params:\n    item_id: Optional. Specify which bank if multiple connected.","operationId":"sync_transactions_api_plaid_transactions_sync_post","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/plaid/transactions":{"get":{"tags":["plaid"],"summary":"Get Transactions","description":"Get transactions for connected Plaid accounts.\n\nTwo modes:\n1. With start_date + end_date: Fetches directly from Plaid API (live)\n2. Without dates: Returns locally synced transactions from DB\n\nQuery params:\n    item_id: Optional. Filter by specific bank connection.\n    account_id: Optional. Filter by specific account (internal UUID).\n    start_date: Optional. Start of date range (YYYY-MM-DD).\n    end_date: Optional. End of date range (YYYY-MM-DD).\n    count: Number of results (default 100, max 500).\n    offset: Pagination offset (default 0).","operationId":"get_transactions_api_plaid_transactions_get","security":[{"HTTPBearer":[]}],"parameters":[{"name":"item_id","in":"query","required":false,"schema":{"type":"string","title":"Item Id"}},{"name":"account_id","in":"query","required":false,"schema":{"type":"string","title":"Account Id"}},{"name":"start_date","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"Start date (YYYY-MM-DD). If provided with end_date, fetches from Plaid directly.","title":"Start Date"},"description":"Start date (YYYY-MM-DD). If provided with end_date, fetches from Plaid directly."},{"name":"end_date","in":"query","required":false,"schema":{"anyOf":[{"type":"string","format":"date"},{"type":"null"}],"description":"End date (YYYY-MM-DD). Required if start_date is provided.","title":"End Date"},"description":"End date (YYYY-MM-DD). Required if start_date is provided."},{"name":"count","in":"query","required":false,"schema":{"type":"integer","maximum":500,"minimum":1,"description":"Number of transactions per page","default":100,"title":"Count"},"description":"Number of transactions per page"},{"name":"offset","in":"query","required":false,"schema":{"type":"integer","minimum":0,"description":"Pagination offset","default":0,"title":"Offset"},"description":"Pagination offset"}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/subscriptions/me":{"get":{"tags":["subscriptions","subscriptions"],"summary":"Get My Subscription","description":"Get current user's subscription details including overrides","operationId":"get_my_subscription_api_subscriptions_me_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SubscriptionWithOverride"}}}}},"security":[{"HTTPBearer":[]}]}},"/api/subscriptions/plans":{"get":{"tags":["subscriptions","subscriptions"],"summary":"Get Plans","description":"Get all available subscription plans","operationId":"get_plans_api_subscriptions_plans_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"items":{"$ref":"#/components/schemas/SubscriptionPlanResponse"},"type":"array","title":"Response Get Plans Api Subscriptions Plans Get"}}}}}}},"/api/subscriptions/checkout":{"post":{"tags":["subscriptions","subscriptions"],"summary":"Create Checkout Session","description":"Create a Stripe checkout session for subscription","operationId":"create_checkout_session_api_subscriptions_checkout_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schem